{
  "name": "tahti",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "ci:check": "bash scripts/ci-check.sh",
    "tor-exit:check": "node scripts/check-tor-exit-list-fresh.mjs",
    "tor-exit:sync": "node scripts/sync-tor-exit-list.mjs",
    "prod:check-m7": "bash scripts/check-mixcloud-prod.sh",
    "prod:check-revelator": "bash scripts/check-revelator-prod.sh",
    "prod:check-distribution": "bash scripts/check-distribution-prod.sh",
    "prod:readiness": "bash scripts/check-prod-readiness.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash tests/e2e/vital-flows.sh",
    "test:e2e:journeys": "bash tests/e2e/user-journeys.sh",
    "test:e2e:journeys:listener": "bash tests/e2e/journeys/listener.sh",
    "test:e2e:journeys:artist": "bash tests/e2e/journeys/artist.sh",
    "test:e2e:journeys:member": "bash tests/e2e/journeys/member.sh",
    "test:e2e:journeys:director": "bash tests/e2e/journeys/director.sh",
    "test:e2e:journeys:ops": "bash tests/e2e/journeys/ops.sh",
    "test:e2e:journeys:all": "bash tests/e2e/run-all-journeys.sh",
    "test:e2e:journeys:web": "node tests/e2e/user-journeys.mjs",
    "test:e2e:dashboard-player": "bash tests/e2e/journeys/dashboard-player.sh",
    "test:e2e:dashboard-player:web": "node tests/e2e/dashboard-player.mjs",
    "test:e2e:release-upload": "node tests/e2e/release-track-upload.mjs",
    "test:e2e:live-chat": "node tests/e2e/live-chat.mjs",
    "smoke": "bash scripts/unified-smoke.sh",
    "smoke:prod": "bash scripts/unified-smoke.sh --prod",
    "smoke:all": "bash scripts/unified-smoke.sh --all --seed",
    "screenshots": "bash scripts/e2e-screenshots.sh",
    "test:e2e:phase4": "bash tests/e2e/phase-4.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json}\" --ignore-path .gitignore",
    "check:tokens": "bash scripts/check-design-tokens.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "playwright": "^1.60.0",
    "prettier": "^3.3.2",
    "turbo": "^2.0.6",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
