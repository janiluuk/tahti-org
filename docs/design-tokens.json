  "accessibility": {
    "_comment": "WCAG 2.1 contrast ratios for brand (dark) surface accent colors against --bg (#0a0f1e). Calculated per WCAG relative-luminance formula.",
    "contrastAgainstBg": {
      "amber-on-bg":    { "ratio": "9.2:1",  "wcagAA": "pass", "wcagAAA": "pass", "note": "Primary CTA, stat values — excellent" },
      "cyan-on-bg":     { "ratio": "8.2:1",  "wcagAA": "pass", "wcagAAA": "pass", "note": "Player controls, active states" },
      "green-on-bg":    { "ratio": "11.1:1", "wcagAA": "pass", "wcagAAA": "pass", "note": "Live indicator — high contrast required; passes AAA" },
      "coral-on-bg":    { "ratio": "7.0:1",  "wcagAA": "pass", "wcagAAA": "borderline", "note": "Errors/destructive — AA pass, just at AAA threshold" },
      "lavender-on-bg": { "ratio": "6.9:1",  "wcagAA": "pass", "wcagAAA": "fail",  "note": "Membership/grants — AA pass, not AAA" },
      "purple-on-bg":   { "ratio": "4.1:1",  "wcagAA": "fail-small-text", "wcagAAA": "fail", "note": "WARNING: fails AA for body text (< 18px / < 14px bold). Use only for large headings or decorative context." },
      "text-on-bg":     { "ratio": "16.9:1", "wcagAA": "pass", "wcagAAA": "pass", "note": "Primary body text" },
      "muted-on-bg":    { "ratio": "6.4:1",  "wcagAA": "pass", "wcagAAA": "fail",  "note": "Secondary text — AA pass" }
    }
