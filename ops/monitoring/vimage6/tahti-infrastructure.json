          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"vimage|vimage2|vimage3|vimage4|vimage5|vimage6|pi4|pi5|web\"}[5m])) * 100)",
