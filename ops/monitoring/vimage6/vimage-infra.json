      },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{job=\"node\",instance=\"vimage\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))",
          "legendFormat": "receive",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{job=\"node\",instance=\"vimage\",device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))",
          "legendFormat": "transmit",
