{
  "log_level": "info",
  "allowed_origins": [
    "http://localhost:17777",
    "http://localhost:3000",
    "https://tahti.live",
    "https://www.tahti.live",
    "https://*.tahti.live"
  ],
  "api_key": "dev",
  "token_hmac_secret_key": "dev_secret_do_not_use_in_prod",
  "admin": true,
  "admin_password": "dev",
  "admin_secret": "dev",
  "history_size": 100,
  "history_ttl": "24h",
  "presence": true,
  "join_leave": true,
  "granular_proxy_mode": true,
  "proxies": [
    {
      "name": "chat_publish",
      "endpoint": "http://api:3001/api/chat/message",
      "timeout": "5s"
    }
  ],
  "namespaces": [
    {
      "name": "channel",
      "presence": true,
      "join_leave": true,
      "history_size": 200,
      "history_ttl": "24h",
      "allow_subscribe_for_client": true,
      "publish_proxy_name": "chat_publish"
    },
    {
      "name": "reactions",
      "presence": false,
      "join_leave": false,
      "history_size": 0,
      "history_ttl": "0s"
    }
  ]
}
