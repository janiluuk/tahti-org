# ─────────────────────────────────────────────────────────────────────────────
# Lab / production stack on vimage (192.168.2.100)
#
# Copy to infra/stack.env on vimage (chmod 600). deploy_prod.sh loads it automatically.
# Outbound mail is handled by Postfix on vimage6 (192.168.2.105) — do not run an MTA on vimage.
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST=mail.tahti.live
SMTP_PORT=587
SMTP_USER=noreply@tahti.live
SMTP_PASS=
SMTP_FROM="Tahti <noreply@tahti.live>"

# Public URLs for links in outbound mail (beta invite, verify, etc.)
APP_URL=https://app.tahti.live
API_URL=https://api.tahti.live

# Icecast ingest (Mixxx / source clients)
ICECAST_PUBLIC_URL=https://ingest-icecast.tahti.live
ICECAST_INGEST_HOSTS=https://ingest-icecast.tahti.live
