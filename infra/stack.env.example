# ─────────────────────────────────────────────────────────────────────────────
# Tahti production stack environment
# Copy to stack.env and fill in real values before deploying.
# stack.env is .gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# Image tag to deploy (set by CI, or pin a version for manual deploys)
TAG=latest

# Registry (self-hosted, on the manager node or a dedicated box)
REGISTRY=registry.tahti.live

# Public hostnames ─────────────────────────────────────────────────────────
PUBLIC_CDN_BASE=https://cdn.tahti.live
PUBLIC_HLS_BASE=https://stream.tahti.live

# Internal API base for Next.js SSR (stays inside the overlay network)
INTERNAL_API_BASE=http://api:3000

# Next.js public env vars (embedded into the client bundle at build time)
NEXT_PUBLIC_API_BASE=https://api.tahti.live
NEXT_PUBLIC_CHAT_BASE=https://chat.tahti.live
NEXT_PUBLIC_HLS_BASE=https://stream.tahti.live

# Ops email for Caddy ACME / Let's Encrypt
CADDY_ACME_EMAIL=ops@tahti.live

# Ingest failover (STREAM-003 / STREAM-007) — set on api via docker-stack.yml
# ICECAST_INGEST_HOSTS=https://ingest-icecast.tahti.live,https://ingest-icecast-b.tahti.live
# RTMP_INGEST_HOSTS=ingest.tahti.live,ingest-b.tahti.live
# DNS: A records for ingest*.tahti.live → Swarm nodes labeled ingest_id=a|b

# Track identification (STREAM-008) — Docker secrets on manager:
#   echo -n "$KEY" | docker secret create acrcloud_access_key -
#   echo -n "$SECRET" | docker secret create acrcloud_access_secret -
#   echo -n "$KEY" | docker secret create acoustid_api_key -
# Empty secrets disable ACRCloud / AcoustID lookup gracefully.

# Mixcloud distribution (M7) — register app at https://www.mixcloud.com/developers/
# Redirect URI: https://api.tahti.live/api/me/mixcloud/oauth/callback
MIXCLOUD_CLIENT_ID=
# Secret via Docker: echo -n "$SECRET" | docker secret create mixcloud_client_secret -
# Optional override (defaults to {API_URL}/api/me/mixcloud/oauth/callback):
# MIXCLOUD_OAUTH_REDIRECT_URI=https://api.tahti.live/api/me/mixcloud/oauth/callback
