{
    email ops@tahti.live
    admin 0.0.0.0:2019
}

# ── Marketing site ────────────────────────────────────────────────────────────
tahti.live, www.tahti.live {
    encode zstd gzip
    reverse_proxy website:80
}

# ── Artist app ────────────────────────────────────────────────────────────────
app.tahti.live {
    encode zstd gzip
    reverse_proxy web:3000
}

# ── Per-channel landing pages — wildcard subdomain routing ───────────────────
*.tahti.live {
    @app host app.tahti.live
    @valid expression {labels.0} != "www" && {labels.0} != "app" && {labels.0} != "api" && {labels.0} != "chat" && {labels.0} != "stream" && {labels.0} != "cdn" && {labels.0} != "ingest-icecast" && {labels.0} != "ingest-icecast-b" && {labels.0} != "minio" && {labels.0} != "grafana"
    encode zstd gzip
    reverse_proxy @valid web:3000 {
        header_up X-Tahti-Channel-Slug {labels.0}
    }
    tls {
        on_demand
    }
}

# ── Artist API ────────────────────────────────────────────────────────────────
api.tahti.live {
    encode zstd gzip
    # Internal ingest callbacks are Docker-network only (SEC-001).
    @internal path /internal/*
    respond @internal 403
    # CORS is handled by the API itself (apps/api/src/plugins/cors.ts) — it
    # reflects the actual matched origin (incl. *.tahti.live channel pages),
    # which a static header here can't do, and covers OPTIONS preflights too.
    reverse_proxy api:3000
}

# ── Centrifugo WebSocket for live chat ────────────────────────────────────────
chat.tahti.live {
    @ws header Connection *Upgrade*
    @ws header Upgrade websocket
    reverse_proxy @ws chat:8000
    reverse_proxy chat:8000
}

# ── Public HLS streams — MinIO hls-live bucket (STREAM-001; synced from Liquidsoap volume) ─
stream.tahti.live {
    log {
        output file /var/log/caddy/hls-access.log {
            roll_size 100mb
            roll_keep 3
        }
        format json
    }
    encode gzip
    header Access-Control-Allow-Origin "*"
    header Cache-Control "public, max-age=2, s-maxage=10"
    rewrite * /hls-live{uri}
    reverse_proxy minio:9000
}

# ── CDN origin for archive items, covers, waveforms ──────────────────────────
cdn.tahti.live {
    reverse_proxy minio:9000
    header Cross-Origin-Resource-Policy "cross-origin"
    header Cache-Control "public, max-age=86400"
}

# ── Icecast ingest ────────────────────────────────────────────────────────────
ingest-icecast.tahti.live {
    reverse_proxy icecast:8000
}

ingest-icecast-b.tahti.live {
    reverse_proxy icecast-b:8000
}

# ── MinIO admin console — restrict to ops IPs ────────────────────────────────
minio.tahti.live {
    @allowed remote_ip 127.0.0.1/32 10.0.0.0/8
    reverse_proxy @allowed minio:9001
    respond 403
}

# ── Grafana dashboards — restrict to ops IPs ─────────────────────────────────
grafana.tahti.live {
    @allowed remote_ip 127.0.0.1/32 10.0.0.0/8
    reverse_proxy @allowed grafana:3000
    respond 403
}

# ── Custom domains (PLAT-051) — artist-owned domains pointing to the platform ─
# Artists add a CNAME/A record to this server, then verify via DNS TXT record.
# On-demand TLS provisions a Let's Encrypt cert automatically on first hit.
# Next.js reads X-Tahti-Custom-Host and resolves the channel via /api/v1/custom-domain/resolve.
:443 {
    @custom_domain {
        not host tahti.live www.tahti.live app.tahti.live api.tahti.live chat.tahti.live stream.tahti.live cdn.tahti.live ingest-icecast.tahti.live ingest-icecast-b.tahti.live minio.tahti.live grafana.tahti.live *.tahti.live
    }
    handle @custom_domain {
        encode zstd gzip
        reverse_proxy web:3000 {
            header_up X-Tahti-Custom-Host {http.request.host}
        }
        tls {
            on_demand
        }
    }
}
