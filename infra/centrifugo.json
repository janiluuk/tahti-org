{
  "log_level": "info",
  "allowed_origins": ["https://tahti.live", "https://www.tahti.live", "https://*.tahti.live"],
  "websocket_compression": true,
  "client_anonymous": false,
  "history_size": 100,
  "history_ttl": "1h",
  "presence": true,
  "join_leave": true,
  "granular_proxy_mode": true,
  "proxies": [
    {
      "name": "chat_publish",
      "endpoint": "http://api:3000/api/chat/message",
      "timeout": "5s"
    }
  ],
  "namespaces": [
    {
      "name": "channel",
      "presence": true,
      "join_leave": true,
      "history_size": 200,
      "history_ttl": "1h",
      "allow_subscribe_for_client": true,
      "publish_proxy_name": "chat_publish"
    },
    {
      "name": "reactions",
      "presence": false,
      "join_leave": false,
      "history_size": 0,
      "history_ttl": "0s"
    }
  ]
}
