# /srv/giggi-site/.env — copy this file, fill in all values, chmod 600 .env
#
# Generate secrets:
#   openssl rand -base64 32  (for passwords / secrets)
#   openssl rand -base64 48  (for SESSION_SECRET — needs more entropy)

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=tahti
POSTGRES_DB=tahti
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=tahti
MINIO_ROOT_PASSWORD=CHANGE_ME
# Publicly reachable URL for presigned download links (can be same host as APP_URL)
MINIO_PUBLIC_ENDPOINT=http://192.168.2.100:9000

# ── App URLs ─────────────────────────────────────────────────────────────────
APP_URL=http://192.168.2.100:3000
API_URL=http://192.168.2.100:3001

# ── Auth ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_48_CHARS

# ── Centrifugo (chat) ─────────────────────────────────────────────────────────
CENTRIFUGO_API_KEY=CHANGE_ME
CENTRIFUGO_SECRET=CHANGE_ME

# ── API internal ─────────────────────────────────────────────────────────────
INTERNAL_SECRET=CHANGE_ME

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Image registry / tag ─────────────────────────────────────────────────────
# Leave REGISTRY blank to build locally (see ops/giggi-site/build-and-deploy.sh)
REGISTRY=registry.tahti.live
TAG=latest
