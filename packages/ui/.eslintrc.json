{
  "extends": ["../../.eslintrc.json"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "env": { "browser": true },
  "overrides": [
    {
      "files": ["src/tokens.ts", "src/admin/index.ts"],
      "rules": { "no-restricted-syntax": "off" }
    }
  ]
}
