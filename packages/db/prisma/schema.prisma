  @@schema("channel")
}

// Derived-but-stored quality signal — see packages/shared/src/quality.ts for the source matrix.
enum ArchiveQualityBadge {
  LOSSLESS
  TRANSCODED
  EMBED_ONLY

  @@schema("channel")
}

enum ArchiveEmbedProvider {
  SPOTIFY
  MIXCLOUD
  YOUTUBE
  APPLE
  GENERIC

  @@schema("channel")
}

enum ArchiveLicense {
  ALL_RIGHTS_RESERVED
  CC_BY
  CC_BY_NC
  CC_BY_NC_SA
  CC_BY_NC_ND
  CC_BY_SA
  CC0

  @@schema("channel")
}

enum BroadcastSource {
  RTMP
  ICECAST
  WEBRTC

  @@schema("channel")
}

enum RtmpTargetProvider {
  YOUTUBE
  TWITCH
  FACEBOOK
  KICK
  TIKTOK
  MIXCLOUD_LIVE
  INSTAGRAM
  CUSTOM

  @@schema("channel")
}

