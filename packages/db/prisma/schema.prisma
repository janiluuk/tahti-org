generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "channel", "chat", "ledger", "governance"]
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum ArtistTier {
  FREE
  ARTIST
  STUDIO

  @@schema("core")
}

enum MembershipStatus {
  PENDING_EMAIL
  ACTIVE
  SUSPENDED
  RESIGNED

  @@schema("core")
}

enum ChannelState {
  OFFLINE
  LIVE

  @@schema("channel")
}

enum ArchiveItemStatus {
  PENDING
  PROCESSING
  READY
  ERROR

  @@schema("channel")
}

enum BroadcastSource {
  RTMP
  ICECAST
  WEBRTC

  @@schema("channel")
}

enum RtmpTargetProvider {
  YOUTUBE
  TWITCH
  FACEBOOK
  MIXCLOUD_LIVE
  CUSTOM

  @@schema("channel")
}

enum LedgerCategory {
  REVENUE_SUBSCRIPTION
  REVENUE_DISTRIBUTION
  REVENUE_GRANT_INBOUND
  REVENUE_DONATION
  COST_INFRASTRUCTURE
  COST_DISTRIBUTION_PASSTHROUGH
  COST_OPERATIONS
  COST_SALARY
  COST_AUDIT
  COST_PROFESSIONAL_SERVICES
  GRANT_DISBURSEMENT
  RESERVE_TRANSFER

  @@schema("ledger")
}

enum AuditAction {
  CHAT_BAN
  CHAT_UNBAN
  CHAT_MESSAGE_DELETE
  STREAM_KEY_ROTATE
  RTMP_TARGET_ADD
  RTMP_TARGET_DELETE
  LEDGER_ENTRY_CREATE
  MEMBER_SUSPEND
  MEMBER_REINSTATE

  @@schema("governance")
}

// ── Core schema ───────────────────────────────────────────────────────────────

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  emailVerifiedAt       DateTime?
  passwordHash          String
  username              String     @unique
  displayName           String
  bio                   String?
  avatarUrl             String?
  socialLinks           Json?
  tipJarUrl             String?
  tier                  ArtistTier @default(FREE)
  isMember              Boolean    @default(false)
  memberNumber          Int?       @unique
  memberSince           DateTime?
  publicAttribution     Boolean    @default(true)
  stripeCustomerId      String?
  softTargetBytes       BigInt     @default(524288000)
  hiddenCeilingBytes    BigInt     @default(53687091200)
  storageUsedBytes      BigInt     @default(0)
  weeklyLiveSecondsUsed Int        @default(0)
  weeklyLiveResetAt     DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  sessions           Session[]
  emailVerifications EmailVerification[]
  membership         Membership?
  channel            Channel?

  @@schema("core")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@schema("core")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@schema("core")
}

model Membership {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      MembershipStatus @default(PENDING_EMAIL)
  activatedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@schema("core")
}

// ── Channel schema ────────────────────────────────────────────────────────────

model Channel {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug               String       @unique
  customDomain       String?
  state              ChannelState @default(OFFLINE)
  containerId        String?
  liveSourceMount    String
  liveSourcePass     String
  liveSourcePassHash String
  rtmpStreamKey      String
  rtmpStreamKeyHash  String
  webrtcTokenHash    String?
  fallbackMode       String       @default("shuffle")
  totalLiveHours     Float        @default(0)
  totalListenerHours BigInt       @default(0)
  goneLiveAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  archiveItems   ArchiveItem[]
  broadcasts     Broadcast[]
  announcements  ChannelAnnouncement[]
  chatBans       ChatBan[]
  rtmpTargets    RtmpTarget[]

  @@schema("channel")
}

model Broadcast {
  id            String          @id @default(cuid())
  channelId     String
  channel       Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  source        BroadcastSource
  startedAt     DateTime        @default(now())
  endedAt       DateTime?
  recordingKey  String?
  archiveItemId String?         @unique

  @@index([channelId, startedAt(sort: Desc)])
  @@schema("channel")
}

model ChannelAnnouncement {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([channelId, createdAt(sort: Desc)])
  @@schema("channel")
}

// Encrypted stream key stored as base64(nonce+ciphertext); key comes from
// RTMP_KEY_ENC_KEY env var (32-byte hex). plaintext key never stored unencrypted.
model RtmpTarget {
  id           String             @id @default(cuid())
  channelId    String
  channel      Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  provider     RtmpTargetProvider
  label        String
  rtmpUrl      String
  streamKeyEnc String
  alwaysMirror Boolean            @default(false)
  enabled      Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([channelId])
  @@schema("channel")
}

model ArchiveItem {
  id            String            @id @default(cuid())
  channelId     String
  channel       Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  rawKey        String
  mp3Key        String?
  durationSec   Int?
  fileSizeBytes BigInt
  status        ArchiveItemStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([channelId, createdAt(sort: Desc)])
  @@schema("channel")
}

// ── Chat schema ───────────────────────────────────────────────────────────────

model ChatBan {
  id              String   @id @default(cuid())
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  fingerprintHash String
  bannedAt        DateTime @default(now())

  @@unique([channelId, fingerprintHash])
  @@schema("chat")
}

// ── Ledger schema (append-only) ───────────────────────────────────────────────

model LedgerEntry {
  id           BigInt          @id @default(autoincrement())
  category     LedgerCategory
  amountCents  BigInt
  currency     String          @default("EUR")
  description  String
  externalRef  String?
  periodStart  DateTime
  periodEnd    DateTime
  createdAt    DateTime        @default(now())
  createdBy    String

  @@index([category, periodStart])
  @@index([createdAt])
  @@schema("ledger")
}

model MonthlyRollup {
  yearMonth   String   @id
  byCategory  Json
  surplus     BigInt
  finalizedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("ledger")
}

// ── Governance schema ─────────────────────────────────────────────────────────

model AuditLog {
  id         BigInt      @id @default(autoincrement())
  action     AuditAction
  actorId    String
  targetId   String?
  meta       Json?
  createdAt  DateTime    @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@schema("governance")
}
