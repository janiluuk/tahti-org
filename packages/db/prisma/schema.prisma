// ── Core schema ───────────────────────────────────────────────────────────────

model CloudImportJob {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  source           CloudImportSource
  externalFileId   String
  fileName         String?
  archiveItemId    String?           @unique
  archiveItem      ArchiveItem?      @relation(fields: [archiveItemId], references: [id])
  status           CloudImportStatus @default(QUEUED)
  error            String?
  bytesTransferred BigInt?
  queuedAt         DateTime          @default(now())
  completedAt      DateTime?

  @@index([userId, queuedAt(sort: Desc)])
  @@schema("core")
}

model User {
  id                             String     @id @default(cuid())
  email                          String     @unique
  emailVerifiedAt                DateTime?
  passwordHash                   String?
  username                       String     @unique
  displayName                    String
  bio                            String?
  avatarUrl                      String?
  socialLinks                    Json?
  tipJarUrl                      String?
  countryCode                    String?
  pronouns                       String?
  tier                           ArtistTier @default(FREE)
  isMember                       Boolean    @default(false)
  isBoard                        Boolean    @default(false)
  memberNumber                   Int?       @unique
  memberSince                    DateTime?
  publicAttribution              Boolean    @default(true)
  stripeCustomerId               String?
  stripeMembershipSubscriptionId String?    @unique
  stripeConnectAccountId         String?    @unique
  stripeConnectChargesEnabled    Boolean    @default(false)
  softTargetBytes                BigInt     @default(524288000)
  hiddenCeilingBytes             BigInt     @default(53687091200)
  storageUsedBytes               BigInt     @default(0)
  weeklyLiveSecondsUsed          Int        @default(0)
  weeklyLiveResetAt              DateTime?
  mentionsEnabled                Boolean    @default(true)
  publicMentionsEnabled          Boolean    @default(false)
  suspendedAt                    DateTime?
  suspendReason                  String?
  deletedAt                      DateTime?
  mixcloudAccessTokenEnc         String? // M7: OAuth access token (AES-GCM, same key as RTMP)
  bandcampAccessTokenEnc         String? // Sprint 9: Bandcamp import OAuth
  soundcloudAccessTokenEnc       String? // Sprint 9: SoundCloud import OAuth
  googleDriveAccessTokenEnc      String? // PLAT-080: Google Drive import OAuth
  googleDriveRefreshTokenEnc     String? // PLAT-083: encrypted refresh token
  spotifyArtistId                String? // mixed-source collections brief: resolved Spotify artist catalog ID for "Your tracks" — search itself uses an app-level token, no per-user OAuth
  mixcloudUsername               String? // mixed-source collections brief: artist's own Mixcloud handle for "Your tracks" — Mixcloud's read API is public, no OAuth needed for catalog browsing
  createdAt                      DateTime   @default(now())
  updatedAt                      DateTime   @updatedAt

  sessions                 Session[]
  emailVerifications       EmailVerification[]
  membership               Membership?
  channel                  Channel?
  motionsProposed          Motion[]
  votes                    Vote[]
  grants                   GrantDisbursement[]
  fanTiers                 FanTier[]
  fanSubsAsArtist          FanSubscription[]        @relation("ArtistFanSubs")
  fanSubsAsSubscriber      FanSubscription[]        @relation("SubscriberFanSubs")
  releases                 Release[]
  revelatorRoyaltyReports  RevelatorRoyaltyReport[]
  mixUploads               MixUpload[]
  cloudImportJobs          CloudImportJob[]
  newsletterSubscribers    NewsletterSubscriber[]   @relation("ArtistSubscribers")
  newsletterDrafts         NewsletterDraft[]
  mentionsSent             Mention[]                @relation("MentionerMentions")
  mentionsReceived         Mention[]                @relation("MentionTarget")
  mentionsMuted            MentionMute[]            @relation("MuterMutes")
  mentionsMutedBy          MentionMute[]            @relation("MuteTarget")
  collections              Collection[]
  artistFollowers          ArtistFollow[]           @relation("ArtistFollowers")
  artistFollowing          ArtistFollow[]           @relation("ArtistFollowing")
  supportTickets           SupportTicket[]          @relation("SupportTicketArtist")
  supportTicketsAssigned   SupportTicket[]          @relation("SupportAssignee")
  supportTicketNotes       SupportTicketNote[]
  boardResolutionsCreated  BoardResolution[]
  annualReportsGenerated   AnnualReport[]
  socialConnections        SocialConnection[]
  socialPosts              SocialPost[]
  stashFiles               StashFile[]
  betaApplication          BetaApplication?
  betaApplicationsReviewed BetaApplication[]        @relation("BetaReviewedBy")
  passwordSetups           PasswordSetup[]
  editorProjects           EditorProject[]
  moderatorOf              ChannelModerator[]

  @@schema("core")
}

model EditorProject {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  archiveItemId String?
  timeline      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
  @@schema("core")
}

model BetaApplication {
  id           String                @id @default(cuid())
  name         String
  email        String
  artistType   String
  links        String?
  message      String?
  source       String
  status       BetaApplicationStatus @default(PENDING)
  userId       String?               @unique
  user         User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?                 @relation("BetaReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([email])
  @@index([status, createdAt])
  @@schema("core")
}

model PasswordSetup {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@schema("core")
}

model SocialConnection {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform           SocialPlatform
  instanceUrl        String
  externalAccountId  String?
  accessTokenEnc     String
  onReleasePublished Boolean        @default(false)
  onChannelLive      Boolean        @default(false)
  postTemplate       String         @default("New release: {release} by {artist} — {smart_link}")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([userId, platform])
  @@schema("core")
}

model SocialPost {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   SocialPlatform
  trigger    String
  releaseId  String?
  channelId  String?
  message    String
  state      SocialPostState @default(PENDING)
  externalId String?
  error      String?
  attempts   Int             @default(0)
  createdAt  DateTime        @default(now())
  sentAt     DateTime?

  @@index([userId, createdAt])
  @@schema("core")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@schema("core")
}

// PLAT-038: private WIP file storage
model StashFile {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename    String
  objectKey   String // MinIO key
  contentType String
  sizeBytes   BigInt
  format      String? // FLAC, WAV, MP3, ZIP, etc.
  bitDepth    Int?
  sampleRate  Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  shares      StashShare[]

  @@index([userId, createdAt(sort: Desc)])
  @@schema("core")
}

model StashShare {
  id              String    @id @default(cuid())
  fileId          String
  file            StashFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  granteeUsername String?
  token           String    @unique @default(cuid())
  permission      String    @default("READ")
  fileCount       Int       @default(1)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([token])
  @@schema("core")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@schema("core")
}

model Membership {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      MembershipStatus @default(PENDING_EMAIL)
  activatedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@schema("core")
}

// ── Channel schema ────────────────────────────────────────────────────────────

model Channel {
  id                              String                @id @default(cuid())
  userId                          String                @unique
  user                            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                            String                @unique
  customDomain                    String?
  customDomainVerified            Boolean               @default(false)
  state                           ChannelState          @default(OFFLINE)
  containerId                     String?
  liveSourceMount                 String
  liveSourcePass                  String
  liveSourcePassHash              String
  rtmpStreamKey                   String
  rtmpStreamKeyHash               String
  rtmpStreamKeyPreviousHash       String? // ARTIST-002 hot rotation grace
  rtmpStreamKeyPreviousExpiresAt  DateTime?
  liveSourcePassPreviousHash      String?
  liveSourcePassPreviousExpiresAt DateTime?
  webrtcTokenHash                 String?
  fallbackMode                    String                @default("shuffle")
  totalLiveHours                  Float                 @default(0)
  totalListenerHours              BigInt                @default(0)
  goneLiveAt                      DateTime?
  metaStreamOptOut                Boolean               @default(false)
  galleryMode                     ChannelGalleryMode    @default(NONE)
  slideshowImages                 String[] // M24: ordered image URLs for channel gallery
  textLayerMode                   ChannelTextLayerMode  @default(NONE)
  textLayerText                   String                @default("")
  textLayerAlign                  ChannelTextLayerAlign @default(CENTER)
  videoBackgroundUrl              String? // M26: YouTube/Vimeo or image URL for channel backdrop
  // M31: visual customization
  colorSchemeJson                 String? // JSON {bg,accent,text,muted,highlight} hex overrides
  visualPreset                    VisualPreset          @default(MINIMAL)
  slideshowPreset                 SlideshowPreset       @default(FADE)
  slideshowIntervalSeconds        Int                   @default(8)
  slideshowTransitionMs           Int                   @default(600)
  slideshowAutoplay               Boolean               @default(true)
  nextBroadcastAt                 DateTime? // LISTENER-002: optional next live time for offline listeners
  nextBroadcastNote               String? // e.g. "Weekly show — Thursdays 22:00 EET"
  lastFeaturedAt                  DateTime? // M16: Tahti Radio fair rotation
  createdAt                       DateTime              @default(now())
  updatedAt                       DateTime              @updatedAt

  archiveItems     ArchiveItem[]
  broadcasts       Broadcast[]
  announcements    ChannelAnnouncement[]
  chatBans         ChatBan[]
  moderators       ChannelModerator[]
  rtmpTargets      RtmpTarget[]
  radioFeatureLogs RadioFeatureLog[]

  @@index([state])
  @@schema("channel")
}

model RadioFeatureLog {
  id         String   @id @default(cuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  featuredAt DateTime @default(now())

  @@index([featuredAt(sort: Desc)])
  @@schema("channel")
}

model Broadcast {
  id            String          @id @default(cuid())
  channelId     String
  channel       Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  source        BroadcastSource
  startedAt     DateTime        @default(now())
  /// Set when this session was promoted PREVIEW -> LIVE. Null means it never went public — skip archive finalization.
  wentLiveAt    DateTime?
  endedAt       DateTime?
  recordingKey  String?
  archiveItemId String?         @unique

  @@index([channelId, startedAt(sort: Desc)])
  @@schema("channel")
}

model ChannelAnnouncement {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([channelId, createdAt(sort: Desc)])
  @@schema("channel")
}

// Encrypted stream key stored as base64(nonce+ciphertext); key comes from
// RTMP_KEY_ENC_KEY env var (32-byte hex). plaintext key never stored unencrypted.
model RtmpTarget {
  id           String             @id @default(cuid())
  channelId    String
  channel      Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  provider     RtmpTargetProvider
  label        String
  rtmpUrl      String
  streamKeyEnc String
  alwaysMirror Boolean            @default(false)
  enabled      Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([channelId])
  @@schema("channel")
}

model ArchiveItem {
  id                   String                @id @default(cuid())
  channelId            String
  channel              Channel               @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title                String
  description          String?
  tracklist            Json? // M22: [{startSec, title, artist?, artistUsername?}]
  editList             Json? // Pro editor v3 draft (@tahti/audio-edit EditList v1)
  editorPeaks          Json? // Pro editor: PeaksPyramid from ingest (PERF-04)
  bannerUrl            String? // M24: cover image URL
  backgroundUrl        String? // per-track background image
  slideshowUrls        String[] // ordered images for track page slideshow
  commentary           String? // M25: artist commentary (Markdown)
  taggedNote           String? // draft @-mention text for collaborators
  genre                String?
  genreCustom          String? // when not in preset genre list
  recordingLocation    String?
  subGenres            String[]              @default([])
  contentType          ArchiveContentType    @default(STUDIO)
  mixVersion           String? // e.g. "Original Mix", "Rok Tek Remix"
  bpm                  Int?
  musicalKey           String?
  bpmDetected          Int?
  keyDetected          String?
  useDetectedBpmKey    Boolean               @default(true)
  isAiGenerated        Boolean               @default(false)
  releasedAt           DateTime              @default(now())
  license              ArchiveLicense        @default(ALL_RIGHTS_RESERVED)
  repostToDownload     Boolean               @default(false)
  followToDownload     Boolean               @default(false)
  rawKey               String? // null for *_EMBED sources — no audio file exists
  mp3Key               String?
  flacKey              String?
  durationSec          Int?
  sourceFormat         String? // detected source codec, e.g. "MP3", "FLAC", "AAC", "WAV"
  sourceBitrateKbps    Int? // detected source bitrate (lossy only); null for lossless
  peaks                Json? // M27: per-set waveform visualisation — [0..255] amplitude buckets
  visualPreset         VisualPreset          @default(MINIMAL) // M31
  fileSizeBytes        BigInt? // null for *_EMBED sources
  source               ArchiveItemSource     @default(UPLOAD)
  qualityBadge         ArchiveQualityBadge   @default(LOSSLESS)
  embedUri             String? // spotify:track:... / mixcloud.com/.../... — present iff source is *_EMBED
  embedProvider        ArchiveEmbedProvider?
  status               ArchiveItemStatus     @default(PENDING)
  isPublic             Boolean               @default(true)
  isFallback           Boolean               @default(false)
  fallbackOrder        Int? // M27: position in ordered offline rotation
  lastFallbackPlayedAt DateTime? // M27: fair shuffle — least recent first
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  mixUpload       MixUpload?
  cloudImportJob  CloudImportJob?
  collectionItems CollectionItem[]
  versions        ArchiveItemVersion[]

  @@index([channelId, createdAt(sort: Desc)])
  @@index([channelId, isPublic, status])
  @@schema("channel")
}

// M28: audio file versions for a single archive track (stable public item id).
model ArchiveItemVersion {
  id                String            @id @default(cuid())
  archiveItemId     String
  archiveItem       ArchiveItem       @relation(fields: [archiveItemId], references: [id], onDelete: Cascade)
  versionNumber     Int
  versionLabel      String
  rawKey            String
  mp3Key            String?
  flacKey           String?
  durationSec       Int?
  sourceFormat      String? // detected source codec, e.g. "MP3", "FLAC", "AAC", "WAV"
  sourceBitrateKbps Int? // detected source bitrate (lossy only); null for lossless
  peaks             Json? // M27: per-set waveform visualisation — [0..255] amplitude buckets
  fileSizeBytes     BigInt            @default(0)
  status            ArchiveItemStatus @default(PENDING)
  isActive          Boolean           @default(false)
  createdAt         DateTime          @default(now())

  @@unique([archiveItemId, versionNumber])
  @@index([archiveItemId, createdAt(sort: Desc)])
  @@schema("channel")
}

// ── Chat schema ───────────────────────────────────────────────────────────────

model ChatBan {
  id              String   @id @default(cuid())
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  fingerprintHash String
  bannedAt        DateTime @default(now())

  @@unique([channelId, fingerprintHash])
  @@schema("chat")
}

// M27: trusted listeners delegated chat moderation (ban/unban) by the channel owner
model ChannelModerator {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@unique([channelId, userId])
  @@index([userId])
  @@schema("chat")
}

// ── Ledger schema (append-only) ───────────────────────────────────────────────

model LedgerEntry {
  id          BigInt         @id @default(autoincrement())
  category    LedgerCategory
  amountCents BigInt
  currency    String         @default("EUR")
  description String
  externalRef String?
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime       @default(now())
  createdBy   String

  @@index([category, periodStart])
  @@index([createdAt])
  @@schema("ledger")
}

model MonthlyRollup {
  yearMonth   String    @id
  byCategory  Json
  surplus     BigInt
  finalizedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@schema("ledger")
}

// M9 — annual engagement-unit-weighted grant disbursements. One row per
// eligible artist per fiscal year. Append-only in spirit: a finalized year's
// rows are not recomputed (see docs/planning-decisions.md Topic 8).
model GrantDisbursement {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  forYear      Int
  units        Int
  amountCents  BigInt
  state        GrantState @default(PENDING)
  payoutMethod String?
  payoutRef    String?
  notifiedAt   DateTime?
  confirmedAt  DateTime?
  paidAt       DateTime?
  publishedAs  String
  createdAt    DateTime   @default(now())

  @@unique([userId, forYear])
  @@index([forYear])
  @@schema("ledger")
}

// ── Governance schema ─────────────────────────────────────────────────────────

model AuditLog {
  id        BigInt      @id @default(autoincrement())
  action    AuditAction
  actorId   String
  targetId  String?
  meta      Json?
  createdAt DateTime    @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@schema("governance")
}

// ── Member governance (M10) ───────────────────────────────────────────────────
// Voting is ADVISORY for Y1 (see docs/planning-decisions.md Topic 11). Binding
// AGM decisions require a live meeting until the bylaws authorize asynchronous
// electronic voting; `advisory` flips to false once that clause is filed.

model Motion {
  id          String      @id @default(cuid())
  title       String
  description String
  proposedBy  String
  proposer    User        @relation(fields: [proposedBy], references: [id])
  advisory    Boolean     @default(true)
  openAt      DateTime
  closeAt     DateTime
  state       MotionState @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  votes Vote[]

  @@index([state, closeAt])
  @@schema("governance")
}

model Vote {
  motionId String
  motion   Motion     @relation(fields: [motionId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  choice   VoteChoice
  castAt   DateTime   @default(now())

  @@id([motionId, userId])
  @@index([motionId])
  @@schema("governance")
}

// ── Engagement (M18) ──────────────────────────────────────────────────────────
// Every download is logged for grant accounting. A row that counts toward grants
// has `countedAt` set and a `weight` (1 free, 5 fan-subscriber). Rows that don't
// count (dedup, per-track cap, fraud) keep countedAt NULL with a `reason`.
// See docs/engagement-and-fansubs.md.

model Download {
  id             BigInt    @id @default(autoincrement())
  channelId      String
  archiveItemId  String?
  releaseTrackId String?
  format         String
  byUserId       String?
  byFingerprint  String
  byIpHash       String
  countryCode    String?
  bytes          Int       @default(0)
  countedAt      DateTime?
  reason         String?
  weight         Int       @default(1)
  createdAt      DateTime  @default(now())

  @@index([channelId, countedAt])
  @@index([channelId, createdAt(sort: Desc)])
  @@index([byFingerprint, archiveItemId])
  @@index([archiveItemId, createdAt])
  @@schema("engagement")
}

// M22: lightweight artist follow (unlock follow-gated downloads; not a social graph).
model ArtistFollow {
  followerUserId String
  artistUserId   String
  follower       User     @relation("ArtistFollowing", fields: [followerUserId], references: [id], onDelete: Cascade)
  artist         User     @relation("ArtistFollowers", fields: [artistUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@id([followerUserId, artistUserId])
  @@index([artistUserId])
  @@schema("engagement")
}

// M22: listener acknowledged sharing (repost-gated downloads).
model ArchiveRepostAck {
  id            String   @id @default(cuid())
  archiveItemId String
  byUserId      String?
  byFingerprint String
  createdAt     DateTime @default(now())

  @@unique([archiveItemId, byFingerprint])
  @@index([archiveItemId])
  @@schema("engagement")
}

// ── Fan-to-artist subscriptions (M19) ─────────────────────────────────────────
// Listeners subscribe directly to an artist. Money flows to the artist via
// Stripe Connect minus Stripe fees and a 2% operational fee (passthrough, not
// org revenue — bylaws §11.b). Fan-sub euros and 5× paid-download weighting feed
// the M9 grant formula. See docs/engagement-and-fansubs.md.

model FanTier {
  id           String   @id @default(cuid())
  artistUserId String
  artist       User     @relation(fields: [artistUserId], references: [id], onDelete: Cascade)
  name         String
  amountCents  Int
  description  String?
  perks        String[]
  active       Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([artistUserId, active])
  @@schema("fansubs")
}

model FanSubscription {
  id                   String      @id @default(cuid())
  artistUserId         String
  subscriberUserId     String
  artist               User        @relation("ArtistFanSubs", fields: [artistUserId], references: [id], onDelete: Cascade)
  subscriber           User        @relation("SubscriberFanSubs", fields: [subscriberUserId], references: [id], onDelete: Cascade)
  tierName             String
  amountCents          Int
  stripeSubscriptionId String      @unique
  state                FanSubState @default(ACTIVE)
  startedAt            DateTime    @default(now())
  currentPeriodEnd     DateTime
  canceledAt           DateTime?
  createdAt            DateTime    @default(now())

  payouts FanSubPayout[]

  @@unique([artistUserId, subscriberUserId])
  @@index([artistUserId, state])
  @@index([subscriberUserId, state])
  @@schema("fansubs")
}

model FanSubPayout {
  id                String            @id @default(cuid())
  fanSubscriptionId String
  fanSubscription   FanSubscription   @relation(fields: [fanSubscriptionId], references: [id], onDelete: Cascade)
  artistUserId      String
  forPeriodStart    DateTime
  forPeriodEnd      DateTime
  grossCents        Int
  stripeFeeCents    Int
  orgFeeCents       Int
  netToArtistCents  Int
  stripeTransferId  String?
  state             FanSubPayoutState @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime          @default(now())

  @@index([fanSubscriptionId, forPeriodStart])
  @@index([artistUserId, forPeriodStart])
  @@schema("fansubs")
}

// ── Artist profile releases (M12 + M7 distribution) ────────────────────────

model Release {
  id                          String       @id @default(cuid())
  userId                      String
  user                        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                       String
  type                        ReleaseType
  artworkUrl                  String?
  artworkKey                  String? // M12: cover image in MinIO (presigned for public URLs)
  releaseDate                 DateTime
  description                 String?
  smartLinkSlug               String       @unique
  smartLinkTargets            Json? // {spotify, apple, tidal, bandcamp, ...}
  smartLinkViewCount          Int          @default(0) // M14: public /r/:slug loads
  state                       ReleaseState @default(DRAFT)
  publishedAt                 DateTime?
  commentary                  String? // M25: artist notes on the release (Markdown)
  // M7 — Revelator DSP distribution
  revelatorId                 String?
  revelatorStatus             String? // pending | submitted | delivered | failed
  distributionFeeCents        Int?
  distributionPaidAt          DateTime?
  distributionStripeSessionId String?      @unique
  // M30 — release ops / catalog metadata
  upc                         String?
  musicbrainzReleaseId        String?
  musicbrainzArtistId         String?
  discogsReleaseId            String?
  pLine                       String?
  cLine                       String?
  labelImprint                String?
  credits                     Json? // [{ role, name, artistUsername? }]
  // M31: visual customization
  paletteJson                 String? // extracted from cover art: JSON {bg,accent,text,muted,highlight}
  colorSchemeJson             String? // artist-override JSON {bg,accent,text,muted,highlight}
  visualPreset                VisualPreset @default(MINIMAL)
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt

  tracks                  ReleaseTrack[]
  collectionItems         CollectionItem[]
  revelatorRoyaltyReports RevelatorRoyaltyReport[]
  smartLinkClicks         SmartLinkClick[]

  @@index([userId, releaseDate])
  @@index([userId, state])
  @@schema("release")
}

model SmartLinkClick {
  id        String   @id @default(cuid())
  releaseId String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  platform  String
  referer   String?
  createdAt DateTime @default(now())

  @@index([releaseId, platform])
  @@index([releaseId, createdAt])
  @@schema("release")
}

// M7 — Revelator royalty report snapshots (monthly sync, dashboard display)
model RevelatorRoyaltyReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  releaseId   String
  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  revelatorId String
  periodStart DateTime
  periodEnd   DateTime
  amountCents Int
  currency    String   @default("EUR")
  streams     Int?
  syncedAt    DateTime @default(now())

  @@unique([releaseId, periodStart, periodEnd])
  @@index([userId, periodEnd(sort: Desc)])
  @@schema("release")
}

model ReleaseTrack {
  id                     String      @id @default(cuid())
  releaseId              String
  release                Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  position               Int
  title                  String
  isrc                   String?
  musicbrainzRecordingId String?
  durationSec            Int?
  archiveItemId          String?
  // M12 — audio file pipeline
  sourceKey              String? // original uploaded file in MinIO
  sourceFormat           String? // wav | flac | mp3 | aac | aiff
  sourceSampleRate       Int?
  sourceBitDepth         Int?
  streamKey              String? // Opus 256 kbps derivative
  flacKey                String? // FLAC 16/44 derivative (Studio tier download)
  fingerprint            String?
  explicit               Boolean     @default(false)
  status                 TrackStatus @default(PENDING)
  createdAt              DateTime    @default(now())

  versions ReleaseTrackVersion[]

  @@unique([releaseId, position])
  @@schema("release")
}

// M28: audio file versions for a release track (stable public track id).
model ReleaseTrackVersion {
  id               String       @id @default(cuid())
  releaseTrackId   String
  releaseTrack     ReleaseTrack @relation(fields: [releaseTrackId], references: [id], onDelete: Cascade)
  versionNumber    Int
  versionLabel     String
  sourceKey        String
  sourceFormat     String?
  sourceSampleRate Int?
  sourceBitDepth   Int?
  streamKey        String?
  flacKey          String?
  durationSec      Int?
  status           TrackStatus  @default(PENDING)
  isActive         Boolean      @default(false)
  createdAt        DateTime     @default(now())

  @@unique([releaseTrackId, versionNumber])
  @@index([releaseTrackId, createdAt(sort: Desc)])
  @@schema("release")
}

// M7 — Mixcloud upload for archive items (mixes)
model MixUpload {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  archiveItemId String          @unique
  archiveItem   ArchiveItem     @relation(fields: [archiveItemId], references: [id])
  mixcloudUrl   String?
  mixcloudKey   String?
  status        MixUploadStatus @default(PENDING)
  error         String?
  queuedAt      DateTime        @default(now())
  completedAt   DateTime?

  @@schema("release")
}

// ── Newsletter schema (M13) ──────────────────────────────────────────────────

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  artistUserId   String
  artist         User      @relation("ArtistSubscribers", fields: [artistUserId], references: [id], onDelete: Cascade)
  email          String
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  confirmToken   String?   @unique
  unsubToken     String    @unique
  createdAt      DateTime  @default(now())

  sends NewsletterSend[]

  @@unique([artistUserId, email])
  @@index([artistUserId, confirmedAt])
  @@schema("newsletter")
}

model NewsletterDraft {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         String
  bodyMd          String
  state           NewsletterDraftState @default(DRAFT)
  subscribersOnly Boolean              @default(false) // M19: send only to fan-subscribers
  scheduledAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime             @default(now())

  sends NewsletterSend[]

  @@index([userId, state])
  @@schema("newsletter")
}

model NewsletterSend {
  id           String               @id @default(cuid())
  draftId      String
  draft        NewsletterDraft      @relation(fields: [draftId], references: [id], onDelete: Cascade)
  subscriberId String
  subscriber   NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  state        NewsletterSendState  @default(QUEUED)
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  createdAt    DateTime             @default(now())

  @@index([draftId, state])
  @@schema("newsletter")
}

// ── Venue schema (M17) ───────────────────────────────────────────────────────

model Venue {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  address       String
  city          String
  countryCode   String    @default("FI")
  latitude      Float?
  longitude     Float?
  capacity      Int?
  description   String?
  externalLinks Json?
  photos        String[]
  verifiedAt    DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())

  broadcasts VenueBroadcast[]

  @@schema("venue")
}

model VenueBroadcast {
  id           String              @id @default(cuid())
  venueId      String
  venue        Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  artistUserId String
  startAt      DateTime
  endAt        DateTime?
  description  String?
  channelId    String?
  state        VenueBroadcastState @default(SCHEDULED)
  createdAt    DateTime            @default(now())

  @@index([venueId, startAt])
  @@index([artistUserId, startAt])
  @@schema("venue")
}

// ── Artist @-mentions (M15) ──────────────────────────────────────────────────

model Mention {
  id              String         @id @default(cuid())
  mentionerUserId String
  mentioner       User           @relation("MentionerMentions", fields: [mentionerUserId], references: [id], onDelete: Cascade)
  targetUserId    String
  target          User           @relation("MentionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  surface         MentionSurface
  sourceId        String // bio userId | announcement id | release id | draft id
  notifiedAt      DateTime?
  createdAt       DateTime       @default(now())

  @@unique([mentionerUserId, targetUserId, surface, sourceId])
  @@index([targetUserId, notifiedAt])
  @@schema("core")
}

model MentionMute {
  muterId      String
  muter        User     @relation("MuterMutes", fields: [muterId], references: [id], onDelete: Cascade)
  targetUserId String
  target       User     @relation("MuteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@id([muterId, targetUserId])
  @@schema("core")
}

// ── Collections + catalog UX (M23) ───────────────────────────────────────────

model Collection {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String         @unique
  name        String
  description String?
  type        CollectionType @default(CUSTOM)
  isPublic    Boolean        @default(true)
  isFeatured  Boolean        @default(false) // M23: highlight on profile + smart links
  coverUrl    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Sprint 9: upload + collections flow
  style              CollectionStyle      @default(PLAYLIST)
  visibility         CollectionVisibility @default(PUBLIC)
  coverMode          CollectionCoverMode  @default(AUTO)
  publicProfileOrder Int                  @default(0)
  scheduledPublishAt DateTime?
  smartLinksJson     Json?

  // M26: per-collection backdrop theme (independent of the channel-wide theme)
  galleryMode        CollectionGalleryMode    @default(NONE)
  slideshowImages    String[]
  videoBackgroundUrl String?
  textLayerMode      CollectionTextLayerMode  @default(NONE)
  textLayerText      String                   @default("")
  textLayerAlign     CollectionTextLayerAlign @default(CENTER)

  items CollectionItem[]

  @@index([userId, isPublic])
  @@index([userId, publicProfileOrder])
  @@schema("media")
}

model CollectionItem {
  id            String       @id @default(cuid())
  collectionId  String
  collection    Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  archiveItemId String?
  archiveItem   ArchiveItem? @relation(fields: [archiveItemId], references: [id], onDelete: SetNull)
  releaseId     String?
  release       Release?     @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  position      Int
  createdAt     DateTime     @default(now())

  @@unique([collectionId, position])
  @@index([collectionId, position])
  @@schema("media")
}

// ── Admin schema (M21) ────────────────────────────────────────────────────────

enum CronOutcome {
  SUCCESS
  ERROR

  @@schema("admin")
}

model CronRun {
  id           BigInt       @id @default(autoincrement())
  jobName      String
  startedAt    DateTime
  finishedAt   DateTime?
  outcome      CronOutcome?
  errorMessage String?

  @@index([jobName, startedAt(sort: Desc)])
  @@schema("admin")
}

enum SupportCategory {
  ENGAGEMENT_DISPUTE
  TECHNICAL
  FINANCIAL
  OTHER

  @@schema("admin")
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED

  @@schema("admin")
}

enum ResolutionOutcome {
  PASSED
  FAILED
  DEFERRED

  @@schema("admin")
}

model SupportTicket {
  id           BigInt              @id @default(autoincrement())
  artistId     String?
  artist       User?               @relation("SupportTicketArtist", fields: [artistId], references: [id], onDelete: SetNull)
  contactEmail String?
  subject      String
  message      String
  category     SupportCategory
  status       SupportStatus       @default(OPEN)
  assignedToId String?
  assignedTo   User?               @relation("SupportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes        SupportTicketNote[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@schema("admin")
}

model SupportTicketNote {
  id        BigInt        @id @default(autoincrement())
  ticketId  BigInt
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body      String
  authorId  String?
  author    User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt(sort: Asc)])
  @@schema("admin")
}

model BoardResolution {
  id          BigInt            @id @default(autoincrement())
  title       String
  body        String
  votedAt     DateTime
  outcome     ResolutionOutcome
  voteFor     Int
  voteAgainst Int
  voteAbstain Int
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  publishedAt DateTime?
  createdAt   DateTime          @default(now())

  @@index([votedAt(sort: Desc)])
  @@schema("admin")
}

model AnnualReport {
  id            BigInt   @id @default(autoincrement())
  year          Int      @unique
  storageKey    String
  generatedAt   DateTime @default(now())
  generatedById String
  generatedBy   User     @relation(fields: [generatedById], references: [id], onDelete: Cascade)

  @@schema("admin")
}
