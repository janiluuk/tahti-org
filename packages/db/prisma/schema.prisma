generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "channel", "chat", "ledger", "governance", "engagement", "fansubs", "release", "newsletter", "venue"]
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum ArtistTier {
  FREE
  ARTIST
  STUDIO

  @@schema("core")
}

enum MembershipStatus {
  PENDING_EMAIL
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
  RESIGNED

  @@schema("core")
}

enum ChannelState {
  OFFLINE
  LIVE

  @@schema("channel")
}

enum ArchiveItemStatus {
  PENDING
  PROCESSING
  READY
  ERROR

  @@schema("channel")
}

enum BroadcastSource {
  RTMP
  ICECAST
  WEBRTC

  @@schema("channel")
}

enum RtmpTargetProvider {
  YOUTUBE
  TWITCH
  FACEBOOK
  MIXCLOUD_LIVE
  CUSTOM

  @@schema("channel")
}

enum LedgerCategory {
  REVENUE_SUBSCRIPTION
  REVENUE_DISTRIBUTION
  REVENUE_GRANT_INBOUND
  REVENUE_DONATION
  COST_INFRASTRUCTURE
  COST_DISTRIBUTION_PASSTHROUGH
  COST_OPERATIONS
  COST_SALARY
  COST_AUDIT
  COST_PROFESSIONAL_SERVICES
  GRANT_DISBURSEMENT
  RESERVE_TRANSFER
  FAN_SUB_GROSS_RECEIVED
  FAN_SUB_NET_TO_ARTIST
  FAN_SUB_OPERATIONAL_FEE

  @@schema("ledger")
}

enum GrantState {
  PENDING
  CONFIRMED
  PAID
  UNCLAIMED

  @@schema("ledger")
}

enum AuditAction {
  CHAT_BAN
  CHAT_UNBAN
  CHAT_MESSAGE_DELETE
  STREAM_KEY_ROTATE
  RTMP_TARGET_ADD
  RTMP_TARGET_DELETE
  LEDGER_ENTRY_CREATE
  MEMBER_SUSPEND
  MEMBER_REINSTATE
  MOTION_CREATE
  MOTION_OPEN
  MOTION_CLOSE
  VOTE_CAST
  GRANT_RUN

  @@schema("governance")
}

enum MotionState {
  DRAFT
  OPEN
  CLOSED

  @@schema("governance")
}

enum VoteChoice {
  YES
  NO
  ABSTAIN

  @@schema("governance")
}

enum FanSubState {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED

  @@schema("fansubs")
}

enum FanSubPayoutState {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@schema("fansubs")
}

enum ReleaseType {
  SINGLE
  EP
  ALBUM
  COMPILATION
  REMIX

  @@schema("release")
}

enum ReleaseState {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("release")
}

enum TrackStatus {
  PENDING
  SCANNING
  TRANSCODING
  READY
  FAILED

  @@schema("release")
}

enum MixUploadStatus {
  PENDING
  UPLOADING
  DONE
  FAILED

  @@schema("release")
}

enum NewsletterDraftState {
  DRAFT
  QUEUED
  SENT

  @@schema("newsletter")
}

enum NewsletterSendState {
  QUEUED
  SENT
  FAILED
  BOUNCED

  @@schema("newsletter")
}

enum VenueBroadcastState {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELED

  @@schema("venue")
}

enum MentionSurface {
  BIO
  ANNOUNCEMENT
  RELEASE
  NEWSLETTER

  @@schema("core")
}

// ── Core schema ───────────────────────────────────────────────────────────────

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  emailVerifiedAt       DateTime?
  passwordHash          String
  username              String     @unique
  displayName           String
  bio                   String?
  avatarUrl             String?
  socialLinks           Json?
  tipJarUrl             String?
  tier                  ArtistTier @default(FREE)
  isMember              Boolean    @default(false)
  isBoard               Boolean    @default(false)
  memberNumber          Int?       @unique
  memberSince           DateTime?
  publicAttribution     Boolean    @default(true)
  stripeCustomerId      String?
  softTargetBytes       BigInt     @default(524288000)
  hiddenCeilingBytes    BigInt     @default(53687091200)
  storageUsedBytes      BigInt     @default(0)
  weeklyLiveSecondsUsed Int        @default(0)
  weeklyLiveResetAt     DateTime?
  mentionsEnabled       Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  sessions              Session[]
  emailVerifications    EmailVerification[]
  membership            Membership?
  channel               Channel?
  motionsProposed       Motion[]
  votes                 Vote[]
  grants                GrantDisbursement[]
  fanTiers              FanTier[]
  fanSubsAsArtist       FanSubscription[]        @relation("ArtistFanSubs")
  fanSubsAsSubscriber   FanSubscription[]        @relation("SubscriberFanSubs")
  releases              Release[]
  mixUploads            MixUpload[]
  newsletterSubscribers NewsletterSubscriber[]   @relation("ArtistSubscribers")
  newsletterDrafts      NewsletterDraft[]
  mentionsSent          Mention[]                @relation("MentionerMentions")
  mentionsReceived      Mention[]                @relation("MentionTarget")
  mentionsMuted         MentionMute[]            @relation("MuterMutes")
  mentionsMutedBy       MentionMute[]            @relation("MuteTarget")

  @@schema("core")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@schema("core")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@schema("core")
}

model Membership {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      MembershipStatus @default(PENDING_EMAIL)
  activatedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@schema("core")
}

// ── Channel schema ────────────────────────────────────────────────────────────

model Channel {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug               String       @unique
  customDomain       String?
  state              ChannelState @default(OFFLINE)
  containerId        String?
  liveSourceMount    String
  liveSourcePass     String
  liveSourcePassHash String
  rtmpStreamKey      String
  rtmpStreamKeyHash  String
  webrtcTokenHash    String?
  fallbackMode       String       @default("shuffle")
  totalLiveHours     Float        @default(0)
  totalListenerHours BigInt       @default(0)
  goneLiveAt         DateTime?
  metaStreamOptOut   Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  archiveItems   ArchiveItem[]
  broadcasts     Broadcast[]
  announcements  ChannelAnnouncement[]
  chatBans       ChatBan[]
  rtmpTargets    RtmpTarget[]

  @@schema("channel")
}

model Broadcast {
  id            String          @id @default(cuid())
  channelId     String
  channel       Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  source        BroadcastSource
  startedAt     DateTime        @default(now())
  endedAt       DateTime?
  recordingKey  String?
  archiveItemId String?         @unique

  @@index([channelId, startedAt(sort: Desc)])
  @@schema("channel")
}

model ChannelAnnouncement {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([channelId, createdAt(sort: Desc)])
  @@schema("channel")
}

// Encrypted stream key stored as base64(nonce+ciphertext); key comes from
// RTMP_KEY_ENC_KEY env var (32-byte hex). plaintext key never stored unencrypted.
model RtmpTarget {
  id           String             @id @default(cuid())
  channelId    String
  channel      Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  provider     RtmpTargetProvider
  label        String
  rtmpUrl      String
  streamKeyEnc String
  alwaysMirror Boolean            @default(false)
  enabled      Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([channelId])
  @@schema("channel")
}

model ArchiveItem {
  id            String            @id @default(cuid())
  channelId     String
  channel       Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  rawKey        String
  mp3Key        String?
  flacKey       String?
  durationSec   Int?
  fileSizeBytes BigInt
  status        ArchiveItemStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  mixUpload     MixUpload?

  @@index([channelId, createdAt(sort: Desc)])
  @@schema("channel")
}

// ── Chat schema ───────────────────────────────────────────────────────────────

model ChatBan {
  id              String   @id @default(cuid())
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  fingerprintHash String
  bannedAt        DateTime @default(now())

  @@unique([channelId, fingerprintHash])
  @@schema("chat")
}

// ── Ledger schema (append-only) ───────────────────────────────────────────────

model LedgerEntry {
  id           BigInt          @id @default(autoincrement())
  category     LedgerCategory
  amountCents  BigInt
  currency     String          @default("EUR")
  description  String
  externalRef  String?
  periodStart  DateTime
  periodEnd    DateTime
  createdAt    DateTime        @default(now())
  createdBy    String

  @@index([category, periodStart])
  @@index([createdAt])
  @@schema("ledger")
}

model MonthlyRollup {
  yearMonth   String   @id
  byCategory  Json
  surplus     BigInt
  finalizedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("ledger")
}

// M9 — annual engagement-unit-weighted grant disbursements. One row per
// eligible artist per fiscal year. Append-only in spirit: a finalized year's
// rows are not recomputed (see docs/planning-decisions.md Topic 8).
model GrantDisbursement {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  forYear      Int
  units        Int
  amountCents  BigInt
  state        GrantState @default(PENDING)
  payoutMethod String?
  payoutRef    String?
  notifiedAt   DateTime?
  confirmedAt  DateTime?
  paidAt       DateTime?
  publishedAs  String
  createdAt    DateTime   @default(now())

  @@unique([userId, forYear])
  @@index([forYear])
  @@schema("ledger")
}

// ── Governance schema ─────────────────────────────────────────────────────────

model AuditLog {
  id         BigInt      @id @default(autoincrement())
  action     AuditAction
  actorId    String
  targetId   String?
  meta       Json?
  createdAt  DateTime    @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@schema("governance")
}

// ── Member governance (M10) ───────────────────────────────────────────────────
// Voting is ADVISORY for Y1 (see docs/planning-decisions.md Topic 11). Binding
// AGM decisions require a live meeting until the bylaws authorize asynchronous
// electronic voting; `advisory` flips to false once that clause is filed.

model Motion {
  id          String      @id @default(cuid())
  title       String
  description String
  proposedBy  String
  proposer    User        @relation(fields: [proposedBy], references: [id])
  advisory    Boolean     @default(true)
  openAt      DateTime
  closeAt     DateTime
  state       MotionState @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  votes Vote[]

  @@index([state, closeAt])
  @@schema("governance")
}

model Vote {
  motionId String
  motion   Motion     @relation(fields: [motionId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  choice   VoteChoice
  castAt   DateTime   @default(now())

  @@id([motionId, userId])
  @@index([motionId])
  @@schema("governance")
}

// ── Engagement (M18) ──────────────────────────────────────────────────────────
// Every download is logged for grant accounting. A row that counts toward grants
// has `countedAt` set and a `weight` (1 free, 5 fan-subscriber). Rows that don't
// count (dedup, per-track cap, fraud) keep countedAt NULL with a `reason`.
// See docs/engagement-and-fansubs.md.

model Download {
  id             BigInt    @id @default(autoincrement())
  channelId      String
  archiveItemId  String?
  releaseTrackId String?
  format         String
  byUserId       String?
  byFingerprint  String
  byIpHash       String
  bytes          Int       @default(0)
  countedAt      DateTime?
  reason         String?
  weight         Int       @default(1)
  createdAt      DateTime  @default(now())

  @@index([channelId, countedAt])
  @@index([byFingerprint, archiveItemId])
  @@index([archiveItemId, createdAt])
  @@schema("engagement")
}

// ── Fan-to-artist subscriptions (M19) ─────────────────────────────────────────
// Listeners subscribe directly to an artist. Money flows to the artist via
// Stripe Connect minus Stripe fees and a 2% operational fee (passthrough, not
// org revenue — bylaws §11.b). Fan-sub euros and 5× paid-download weighting feed
// the M9 grant formula. See docs/engagement-and-fansubs.md.

model FanTier {
  id           String   @id @default(cuid())
  artistUserId String
  artist       User     @relation(fields: [artistUserId], references: [id], onDelete: Cascade)
  name         String
  amountCents  Int
  description  String?
  perks        String[]
  active       Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([artistUserId, active])
  @@schema("fansubs")
}

model FanSubscription {
  id                   String      @id @default(cuid())
  artistUserId         String
  subscriberUserId     String
  artist               User        @relation("ArtistFanSubs", fields: [artistUserId], references: [id], onDelete: Cascade)
  subscriber           User        @relation("SubscriberFanSubs", fields: [subscriberUserId], references: [id], onDelete: Cascade)
  tierName             String
  amountCents          Int
  stripeSubscriptionId String      @unique
  state                FanSubState @default(ACTIVE)
  startedAt            DateTime    @default(now())
  currentPeriodEnd     DateTime
  canceledAt           DateTime?
  createdAt            DateTime    @default(now())

  payouts FanSubPayout[]

  @@unique([artistUserId, subscriberUserId])
  @@index([artistUserId, state])
  @@index([subscriberUserId, state])
  @@schema("fansubs")
}

model FanSubPayout {
  id                String            @id @default(cuid())
  fanSubscriptionId String
  fanSubscription   FanSubscription   @relation(fields: [fanSubscriptionId], references: [id], onDelete: Cascade)
  artistUserId      String
  forPeriodStart    DateTime
  forPeriodEnd      DateTime
  grossCents        Int
  stripeFeeCents    Int
  orgFeeCents       Int
  netToArtistCents  Int
  stripeTransferId  String?
  state             FanSubPayoutState @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime          @default(now())

  @@index([fanSubscriptionId, forPeriodStart])
  @@index([artistUserId, forPeriodStart])
  @@schema("fansubs")
}

// ── Artist profile releases (M12 + M7 distribution) ────────────────────────

model Release {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  type             ReleaseType
  artworkUrl       String?
  releaseDate      DateTime
  description      String?
  smartLinkSlug    String       @unique
  smartLinkTargets Json?        // {spotify, apple, tidal, bandcamp, ...}
  state            ReleaseState @default(DRAFT)
  publishedAt      DateTime?
  // M7 — Revelator DSP distribution
  revelatorId      String?
  revelatorStatus  String?      // pending | submitted | delivered | failed
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tracks ReleaseTrack[]

  @@index([userId, releaseDate])
  @@index([userId, state])
  @@schema("release")
}

model ReleaseTrack {
  id               String      @id @default(cuid())
  releaseId        String
  release          Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  position         Int
  title            String
  isrc             String?
  durationSec      Int?
  archiveItemId    String?
  // M12 — audio file pipeline
  sourceKey        String?     // original uploaded file in MinIO
  sourceFormat     String?     // wav | flac | mp3 | aac | aiff
  sourceSampleRate Int?
  sourceBitDepth   Int?
  streamKey        String?     // Opus 256 kbps derivative
  flacKey          String?     // FLAC 16/44 derivative (Studio tier download)
  fingerprint      String?
  explicit         Boolean     @default(false)
  status           TrackStatus @default(PENDING)
  createdAt        DateTime    @default(now())

  @@unique([releaseId, position])
  @@schema("release")
}

// M7 — Mixcloud upload for archive items (mixes)
model MixUpload {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  archiveItemId String          @unique
  archiveItem   ArchiveItem     @relation(fields: [archiveItemId], references: [id])
  mixcloudUrl   String?
  mixcloudKey   String?
  status        MixUploadStatus @default(PENDING)
  error         String?
  queuedAt      DateTime        @default(now())
  completedAt   DateTime?

  @@schema("release")
}

// ── Newsletter schema (M13) ──────────────────────────────────────────────────

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  artistUserId   String
  artist         User      @relation("ArtistSubscribers", fields: [artistUserId], references: [id], onDelete: Cascade)
  email          String
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  confirmToken   String?   @unique
  unsubToken     String    @unique
  createdAt      DateTime  @default(now())

  sends NewsletterSend[]

  @@unique([artistUserId, email])
  @@index([artistUserId, confirmedAt])
  @@schema("newsletter")
}

model NewsletterDraft {
  id          String               @id @default(cuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  bodyMd      String
  state       NewsletterDraftState @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime             @default(now())

  sends NewsletterSend[]

  @@index([userId, state])
  @@schema("newsletter")
}

model NewsletterSend {
  id           String              @id @default(cuid())
  draftId      String
  draft        NewsletterDraft     @relation(fields: [draftId], references: [id], onDelete: Cascade)
  subscriberId String
  subscriber   NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  state        NewsletterSendState @default(QUEUED)
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  createdAt    DateTime            @default(now())

  @@index([draftId, state])
  @@schema("newsletter")
}

// ── Venue schema (M17) ───────────────────────────────────────────────────────

model Venue {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  address       String
  city          String
  countryCode   String    @default("FI")
  latitude      Float?
  longitude     Float?
  capacity      Int?
  description   String?
  externalLinks Json?
  photos        String[]
  verifiedAt    DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())

  broadcasts VenueBroadcast[]

  @@schema("venue")
}

model VenueBroadcast {
  id           String              @id @default(cuid())
  venueId      String
  venue        Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  artistUserId String
  startAt      DateTime
  endAt        DateTime?
  description  String?
  channelId    String?
  state        VenueBroadcastState @default(SCHEDULED)
  createdAt    DateTime            @default(now())

  @@index([venueId, startAt])
  @@index([artistUserId, startAt])
  @@schema("venue")
}

// ── Artist @-mentions (M15) ──────────────────────────────────────────────────

model Mention {
  id              String         @id @default(cuid())
  mentionerUserId String
  mentioner       User           @relation("MentionerMentions", fields: [mentionerUserId], references: [id], onDelete: Cascade)
  targetUserId    String
  target          User           @relation("MentionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  surface         MentionSurface
  sourceId        String         // bio userId | announcement id | release id | draft id
  notifiedAt      DateTime?
  createdAt       DateTime       @default(now())

  @@unique([mentionerUserId, targetUserId, surface, sourceId])
  @@index([targetUserId, notifiedAt])
  @@schema("core")
}

model MentionMute {
  muterId      String
  muter        User    @relation("MuterMutes", fields: [muterId], references: [id], onDelete: Cascade)
  targetUserId String
  target       User    @relation("MuteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@id([muterId, targetUserId])
  @@schema("core")
}
