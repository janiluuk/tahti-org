generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "channel", "chat", "ledger", "governance", "engagement", "fansubs", "release", "newsletter", "venue", "media", "admin"]
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum ArtistTier {
  FREE
  ARTIST
  STUDIO

  @@schema("core")
}

enum MembershipStatus {
  PENDING_EMAIL
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
  RESIGNED

  @@schema("core")
}

enum BetaApplicationStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("core")
}

enum ChannelState {
  OFFLINE
  /// Encoder is connected and the artist can hear it in the studio, but it is not yet public.
  PREVIEW
  LIVE

  @@schema("channel")
}

enum ChannelGalleryMode {
  NONE
  STATIC_SLIDESHOW
  TWISTED_WAVE_GLSL
  ZOOM_BLUR_GLSL
  RGB_SHIFT_GLSL
  POSTER_WALL_GLSL
  SHATTER_CAROUSEL_GLSL

  @@schema("channel")
}

enum ChannelTextLayerMode {
  NONE
  GRADIENT_SHIMMER
  COSMIC_NEON
  LAYERED_WAVE_3D
  SHIMMER_LINES
  GHOST_ECHO

  @@schema("channel")
}

enum ChannelTextLayerAlign {
  LEFT
  CENTER
  RIGHT

  @@schema("channel")
}

// M31: audio-reactive / ambient Three.js visualizer preset for channel + archive items
enum VisualPreset {
  MINIMAL
  WAVEFORM_BARS
  PARTICLE_FIELD
  AURORA
  REACTIVE_GRID

  @@schema("channel")
}

// M31: backdrop slideshow transition style
enum SlideshowPreset {
  FADE
  ZOOM
  PAN
  BLUR_CROSS

  @@schema("channel")
}

enum ArchiveItemStatus {
  PENDING
  PROCESSING
  READY
  ERROR

  @@schema("channel")
}

enum ArchiveContentType {
  LIVE
  STUDIO
  DJ_MIX
  PODCAST
  ORIGINAL
  REMIX
  RADIO_SHOW

  @@schema("channel")
}

// How this ArchiveItem's media was acquired — drives qualityBadge + player choice.
enum ArchiveItemSource {
  UPLOAD
  BROADCAST
  BANDCAMP
  SOUNDCLOUD
  GOOGLE_DRIVE
  MIXCLOUD_RESCUE
  SPOTIFY_EMBED
  MIXCLOUD_EMBED
